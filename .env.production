# Production build env — used automatically by `vite build` (mode=production).
# Overrides .env (localhost) so prod bundles always point at the deployed API.
# An explicit shell `VITE_API_BASE_URL` (e.g. from deploy/dep.sh or CI) still
# takes precedence over this file.
VITE_API_BASE_URL=https://api.sigmaloop.dpdns.org/api/v1
