# ===========================================
# Lambda LAP Frontend — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables must be prefixed with VITE_ to be
# accessible in the client-side code via import.meta.env

# -------------------------------------------
# API Configuration
# -------------------------------------------
VITE_API_BASE_URL=http://localhost:4000/api/v1

# -------------------------------------------
# App Metadata (optional)
# -------------------------------------------
# VITE_APP_NAME=Lambda LAP
# VITE_APP_VERSION=1.0.0
